{
  "manifest_version": 3,
  "name": "Job Capture",
  "version": "1.1",
  "description": "Save job postings to your local job application system",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
